generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id             Int      @id @default(autoincrement())
  slug           String   @unique(map: "BlogPost_slug_key")
  title          String
  summary        String   @db.VarChar(500)
  content        String   @db.Text
  image          String?
  isActive       Boolean  @default(true)
  seoTitle       String?  @db.VarChar(255)
  seoDescription String?  @db.VarChar(500)
  seoKeywords    String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive, createdAt(sort: Desc)])
  @@map("blogpost")
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  service   String?
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("contactsubmission")
}

model ServicePage {
  id              Int      @id @default(autoincrement())
  slug            String   @unique(map: "ServicePage_slug_key")
  title           String
  seoTitle        String?  @db.VarChar(255)
  seoDescription  String?  @db.VarChar(500)
  seoKeywords     String?  @db.Text
  content         String   @db.Text
  image           String?
  category        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isActive        Boolean  @default(true)
  contentTitle    String?  @db.VarChar(255)
  heroDescription String?  @db.VarChar(500)

  @@index([category, isActive])
  @@index([slug, isActive])
  @@map("servicepage")
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  ip        String   @db.VarChar(45)
  timestamp DateTime @default(now())
  success   Boolean

  @@index([ip, timestamp])
  @@map("loginattempt")
}

model SiteSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String @db.LongText

  @@map("sitesetting")
}

model SubdomainContent {
  id              Int      @id @default(autoincrement())
  pageType        String   @unique
  title           String?
  heroTitle       String?  @db.VarChar(255)
  heroDescription String?  @db.VarChar(500)
  seoTitle        String?  @db.VarChar(255)
  seoDescription  String?  @db.VarChar(500)
  seoKeywords     String?  @db.Text
  content         String   @db.Text
  updatedAt       DateTime @updatedAt

  @@map("subdomaincontent")
}

model Job {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String   @unique
  description  String   @db.Text
  requirements String?  @db.Text
  location     String   @default("Ranchi")
  type         String   @default("Full-time")
  experience   String?
  salary       String?
  category     String   @default("Development")
  lastDate     DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt(sort: Desc)])
  @@map("job")
}

model JobApplication {
  id          Int      @id @default(autoincrement())
  jobTitle    String
  name        String
  email       String
  phone       String
  experience  String
  resumeUrl   String
  coverLetter String?  @db.Text
  linkedin    String?
  portfolio   String?
  lockedUntil DateTime?
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("jobapplication")
}

model Redirect {
  id          Int      @id @default(autoincrement())
  source      String   @unique
  destination String
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("redirect")
}

